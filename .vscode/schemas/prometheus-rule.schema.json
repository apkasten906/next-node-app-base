{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PrometheusRule (Prometheus Operator)",
  "type": "object",
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": {
      "type": "string",
      "const": "monitoring.coreos.com/v1"
    },
    "kind": {
      "type": "string",
      "const": "PrometheusRule"
    },
    "metadata": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string" },
        "namespace": { "type": "string" },
        "labels": { "type": "object", "additionalProperties": true },
        "annotations": { "type": "object", "additionalProperties": true }
      },
      "additionalProperties": true
    },
    "spec": {
      "type": "object",
      "properties": {
        "groups": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "interval": { "type": "string" },
              "rules": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": true
                }
              }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
